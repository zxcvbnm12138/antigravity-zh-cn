  "patterns": [
    {
      "match": "^Your Plan:\\s*(.+)$",
      "replace": "当前方案：$1"
    },
    {
      "match": "^Subagents\\s+(\\d+)$",
      "replace": "子智能体 $1"
    },
    {
      "match": "^Files Changed\\s+(\\d+)$",
      "replace": "已改文件 $1"
    },
    {
      "match": "^Artifacts\\s+(\\d+)$",
      "replace": "产物 $1"
    },
    {
      "match": "^Background Tasks\\s+(\\d+)$",
      "replace": "后台任务 $1"
    },
    {
      "match": "^Go To Projects$",
      "replace": "前往项目"
    },
    {
      "match": "^Allow\\s*/\\s*Deny$",
      "replace": "允许 / 拒绝"
    },
    {
      "match": "^allow$",
      "replace": "允许"
    },
    {
      "match": "^deny$",
      "replace": "拒绝"
    },
    {
      "match": "^Allow\\/deny\\s+(.+)$",
      "replace": "允许或拒绝 $1"
    },
    {
      "match": "^Refreshes in (\\d+) hours?, (\\d+) minutes?$",
      "replace": "$1 小时 $2 分钟后刷新"
    },
    {
      "match": "^Refreshes in (\\d+) hours?$",
      "replace": "$1 小时后刷新"
    },
    {
      "match": "^Refreshes in (\\d+) minutes?$",
      "replace": "$1 分钟后刷新"
    },
    {
      "match": "^(\\d+(?:\\.\\d+)?)% of the customization budget is available\\.$",
      "replace": "可用自定义预算为 $1%。"
    },
    {
      "match": "^Show (\\d+) breakdown$",
      "replace": "显示 $1 项明细"
    },
    {
      "match": "^(\\d+) tools enabled$",
      "replace": "已启用 $1 个工具"
    },
    {
      "match": "^(\\d+) rules?$",
      "replace": "$1 条规则"
    },
    {
      "match": "^(\\d+) tools?$",
      "replace": "$1 个工具"
    },
    {
      "match": "^Mcp Tools$",
      "replace": "MCP 工具"
    },
    {
      "match": "^Browser JavaScript Execution Policy$",
      "replace": "浏览器 JavaScript 执行策略"
    },
    {
      "match": "^Navigate to Previous Conversation$",
      "replace": "转到上一个会话"
    },
    {
      "match": "^Navigate to Next Conversation$",
      "replace": "转到下一个会话"
    },
    {
      "match": "^Agent terminated due to error$",
      "replace": "智能体因错误而终止"
    }
  ],
